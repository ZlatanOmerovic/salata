<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>PHP Showcase — Salata</title>
    <style>
        body { font-family: sans-serif; max-width: 700px; margin: 40px auto; padding: 0 20px; color: #333; }
        .section { margin: 25px 0; padding: 15px; background: #f9f9f9; border-radius: 8px; }
        h2 { color: #4F5B93; }
        code { background: #eee; padding: 2px 6px; border-radius: 3px; }
    </style>
</head>
<body>
    <h1>PHP + Python on the Same Page</h1>

    <div class="section">
        <h2>PHP: String &amp; Date Formatting</h2>
        <php>
$now = date('l, F j, Y \a\t g:i A');
echo "<p>Current time: <strong>$now</strong></p>";

$words = str_word_count("Salata is a polyglot templating engine");
echo "<p>Word count: <strong>$words</strong></p>";

$encoded = base64_encode("Hello from PHP!");
echo "<p>Base64: <code>$encoded</code></p>";

$colors = ['#e74c3c', '#3498db', '#2ecc71', '#f39c12'];
echo "<p>Random color: <span style='color:" . $colors[array_rand($colors)] . ";font-weight:bold'>sample text</span></p>";
        </php>
    </div>

    <div class="section">
        <h2>Python: Data Computation</h2>
        <python>
import math

# Compute some values
primes = []
for n in range(2, 50):
    if all(n % i != 0 for i in range(2, int(math.sqrt(n)) + 1)):
        primes.append(n)

print(f"<p>Primes under 50: <code>{', '.join(map(str, primes))}</code></p>")
print(f"<p>Count: <strong>{len(primes)}</strong></p>")
print(f"<p>Sum: <strong>{sum(primes)}</strong></p>")
print(f"<p>Pi to 10 digits: <strong>{math.pi:.10f}</strong></p>")
        </python>
    </div>

    <p><em>This page demonstrates PHP and Python running side-by-side in the same .slt file.</em></p>
</body>
</html>
